{
  "crons": [
    {
      "path": "/api/cron/automations",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "app/api/studio/generate-image/route.ts": {
      "maxDuration": 60
    },
    "app/api/studio/generate-video/route.ts": {
      "maxDuration": 60
    },
    "app/api/studio/tools/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/automations/route.ts": {
      "maxDuration": 60
    },
    "app/api/generate-landing/route.ts": {
      "maxDuration": 60
    },
    "app/api/generate/route.ts": {
      "maxDuration": 60
    },
    "app/api/edit-section/route.ts": {
      "maxDuration": 60
    },
    "app/api/enhance-prompt/route.ts": {
      "maxDuration": 30
    },
    "app/api/competitor-analysis/route.ts": {
      "maxDuration": 60
    },
    "app/api/minishop/import-sections/route.ts": {
      "maxDuration": 60
    },
    "app/api/landing-ia/stream/route.ts": {
      "maxDuration": 60
    },
    "app/api/landing-ia/scrape/route.ts": {
      "maxDuration": 60
    },
    "app/api/studio/ebook/generate/route.ts": {
      "maxDuration": 60
    },
    "app/api/studio/ebook/analyze/route.ts": {
      "maxDuration": 60
    },
    "app/api/studio/ebook/outline/route.ts": {
      "maxDuration": 60
    },
    "app/api/meta-ads/chat/route.ts": {
      "maxDuration": 60
    },
    "app/api/meta-ads/confirm/route.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/admin/:path*", "destination": "https://alldrop-shop-production.up.railway.app/api/admin/:path*" },
    { "source": "/api/auth/:path*", "destination": "https://alldrop-shop-production.up.railway.app/api/auth/:path*" },
    { "source": "/api/store/:path*", "destination": "https://alldrop-shop-production.up.railway.app/api/store/:path*" },
    { "source": "/uploads/:path*", "destination": "https://alldrop-shop-production.up.railway.app/uploads/:path*" },
    { "source": "/constructor", "destination": "https://alldrop-shop.vercel.app/constructor/" },
    { "source": "/constructor/:path*", "destination": "https://alldrop-shop.vercel.app/constructor/:path*" },
    { "source": "/tienda", "destination": "https://alldrop-store.vercel.app/tienda/" },
    { "source": "/tienda/:path*", "destination": "https://alldrop-store.vercel.app/tienda/:path*" }
  ]
}
