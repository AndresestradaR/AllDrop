{
  "crons": [
    {
      "path": "/api/cron/automations",
      "schedule": "*/10 * * * *"
    }
  ],
  "functions": {
    "app/api/studio/generate-image/route.ts": {
      "maxDuration": 120
    },
    "app/api/studio/generate-video/route.ts": {
      "maxDuration": 120
    },
    "app/api/studio/tools/route.ts": {
      "maxDuration": 120
    },
    "app/api/cron/automations/route.ts": {
      "maxDuration": 120
    },
    "app/api/generate-landing/route.ts": {
      "maxDuration": 300
    },
    "app/api/generate/route.ts": {
      "maxDuration": 120
    },
    "app/api/edit-section/route.ts": {
      "maxDuration": 60
    },
    "app/api/enhance-prompt/route.ts": {
      "maxDuration": 30
    },
    "app/api/competitor-analysis/route.ts": {
      "maxDuration": 120
    },
    "app/api/minishop/import-sections/route.ts": {
      "maxDuration": 60
    },
    "app/api/landing-ia/stream/route.ts": {
      "maxDuration": 120
    },
    "app/api/landing-ia/scrape/route.ts": {
      "maxDuration": 60
    },
    "app/api/studio/ebook/generate/route.ts": {
      "maxDuration": 300
    },
    "app/api/studio/ebook/analyze/route.ts": {
      "maxDuration": 60
    },
    "app/api/studio/ebook/outline/route.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/constructor", "destination": "https://shopiestrategas.vercel.app/constructor/" },
    { "source": "/constructor/:path*", "destination": "https://shopiestrategas.vercel.app/constructor/:path*" },
    { "source": "/tienda/:path*", "destination": "https://shopiestrategas-i1em.vercel.app/tienda/:path*" }
  ]
}
